      "then": {
        "recommended_archetypes": ["Switchboard", "Foundry"],
        "branch_tree": "prominent",
        "merge_surfaces": "required"
      }
    },
    {
      "id": "observatory-mode",
      "if": [
        "justice",
        "high-stakes-correctness-mode:maximize verification and cite everything"
